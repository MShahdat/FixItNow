

model User {
  id         String   @id @default(uuid())
  
  firstName  String   
  lastName   String?
  email      String   @unique
  password   String
  phone      String   @unique
  profileImage String?
  address    String?
  city       String?

  role       Role  
  status     UserStatus @default(ACTIVE)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt


  technicianProfile TechnicianProfile?
  customerBookings Booking[]
  reviews Review[]
  payments Payment[]
  
  @@map("users")
}