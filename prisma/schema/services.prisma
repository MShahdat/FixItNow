model Services {
  id String @id @default(uuid())

  technicianProfileId String
  technician          TechnicianProfile @relation(fields: [technicianProfileId], references: [id], onDelete: Cascade)
  categoryId          String
  category            Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  title       String
  description String
  price       Decimal  @db.Decimal(10, 2)
  type        String
  duration    String
  location    String[]
  availableAt String[]
  rating      Decimal @db.Decimal(3, 2) @default(0)
  isActive    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]

  @@index([technicianProfileId])
  @@index([categoryId])

  @@map("services")
}
